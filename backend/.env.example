# ATHENA Backend — Environment Variables
# Copy to .env and fill in your values.
# All sections are optional: leave Deploy.AI empty to run in stub/demo mode.

# ─────────────────────────────────────────────
# Deploy.AI (Complete.dev platform — hackathon default)
# ─────────────────────────────────────────────
DEPLOY_AI_AUTH_URL=https://api-auth.dev.deploy.ai/oauth2/token
DEPLOY_AI_API_URL=https://core-api.dev.deploy.ai
DEPLOY_AI_CLIENT_ID=
DEPLOY_AI_CLIENT_SECRET=
DEPLOY_AI_ORG_ID=

# Agent IDs from the Deploy.AI Agent Builder
SCOUT_AGENT_ID=
STRATEGY_AGENT_ID=

# ─────────────────────────────────────────────
# LLM Provider selection
# Uncomment ONE of the sections below to switch away from Deploy.AI.
# ─────────────────────────────────────────────

# Active provider: deploy_ai | openai | anthropic | ollama
LLM_PROVIDER=deploy_ai

# —— Option 2: OpenAI GPT-4o (direct, fast, requires API key) ——
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# —— Option 3: Anthropic Claude (direct, best reasoning) ——
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# —— Option 4: Ollama — local, free, no data leaves your machine ——
# Install: https://ollama.ai  |  pull model: ollama pull llama3.2
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ─────────────────────────────────────────────
# LATS (Language Agent Tree Search)
# ─────────────────────────────────────────────
LATS_ENABLED=true
# LATS_N_CANDIDATES=2        # parallel candidates per stage (higher = better, slower)
# LATS_QUALITY_THRESHOLD=0.65 # 0–1: score above which early-exit fires
# LATS_MAX_DEPTH=2            # max reflection iterations

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
STUB_MODE=false
REPORTS_DIR=./reports
DEBUG=false
