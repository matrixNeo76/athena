# ATHENA Backend — Environment Variables
# Copy to backend/.env and fill in your values.
#
# TIP: leave everything empty to run in stub/demo mode (no credentials needed).
# TIP: set LLM_PROVIDER=auto to pick the best available provider automatically.

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
STUB_MODE=false
REPORTS_DIR=./reports
DEBUG=false

# ─────────────────────────────────────────────
# LLM provider ─ choose ONE (or use 'auto')
#
#   Provider      Cost        Speed       Setup
#   deploy_ai     platform    medium      Agent IDs required
#   groq          free tier   FASTEST     GROQ_API_KEY
#   openrouter    free/paid   medium      OPENROUTER_API_KEY
#   openai        paid        fast        OPENAI_API_KEY
#   anthropic     paid        medium      ANTHROPIC_API_KEY
#   ollama        FREE        slow*       local install
#   auto          -           -           picks best available
# ─────────────────────────────────────────────
LLM_PROVIDER=deploy_ai

# ─────────────────────────────────────────────
# 1. Deploy.AI (Complete.dev hackathon platform)
# ─────────────────────────────────────────────
DEPLOY_AI_AUTH_URL=https://api-auth.dev.deploy.ai/oauth2/token
DEPLOY_AI_API_URL=https://core-api.dev.deploy.ai
DEPLOY_AI_CLIENT_ID=
DEPLOY_AI_CLIENT_SECRET=
DEPLOY_AI_ORG_ID=
SCOUT_AGENT_ID=
STRATEGY_AGENT_ID=

# ─────────────────────────────────────────────
# 2. Groq — fastest inference, generous FREE tier
#    Key: https://console.groq.com/keys
#    Free models (pick one):
#      llama-3.3-70b-versatile        best quality on free tier (~300 tok/s)
#      llama-3.1-8b-instant           fastest model on Groq    (~750 tok/s)
#      mixtral-8x7b-32768             long context 32K
#      gemma2-9b-it                   Google Gemma 2
#      deepseek-r1-distill-llama-70b  chain-of-thought reasoning
# ─────────────────────────────────────────────
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# 3. OpenRouter — 300+ models, free models available
#    Key: https://openrouter.ai/keys
#    Free models (suffix :free, rate-limited):
#      meta-llama/llama-3.3-70b-instruct:free   best free model
#      deepseek/deepseek-r1:free                best free reasoning
#      google/gemma-2-9b-it:free
#      mistralai/mistral-7b-instruct:free
#      qwen/qwen-2-7b-instruct:free
#    Paid models (excellent price/quality):
#      anthropic/claude-3.5-sonnet
#      openai/gpt-4o
#      deepseek/deepseek-chat                   cheapest strong model
#      google/gemini-flash-1.5                  fast + long context
#      meta-llama/llama-3.1-405b-instruct       largest open model
# ─────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_SITE_URL=https://yoursite.com
# OPENROUTER_SITE_NAME=ATHENA

# ─────────────────────────────────────────────
# 4. OpenAI direct
# ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────
# 5. Anthropic Claude direct
# ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─────────────────────────────────────────────
# 6. Ollama — local, free, private
#    Install: https://ollama.ai
#    Pull:    ollama pull llama3.2
#    Models:  llama3.2 | llama3.1:8b | mistral | qwen2.5:7b |
#             deepseek-r1:7b | gemma2:9b | phi3
# ─────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ─────────────────────────────────────────────
# LATS (Language Agent Tree Search)
# ─────────────────────────────────────────────
LATS_ENABLED=true
# LATS_N_CANDIDATES=2        # parallel candidates (higher = better quality, slower)
# LATS_QUALITY_THRESHOLD=0.65 # 0–1: score above which early-exit fires
# LATS_MAX_DEPTH=2            # max reflection iterations
